---
import "@/styles/global.css";
import config from "./api/config";
import TierColors, {
	formatNumberToLetter,
	GetGatheringProgrssion,
} from "./api/utils";
import type { PlayerInfoResponse } from "./api/PlayerInfo";
import { generatePlayerTags } from "./api/tags";

const apiUrl = `https://gameinfo.albiononline.com/api/gameinfo/players/${config.id}`;
const response = await fetch(apiUrl);
const playerData: PlayerInfoResponse = await response.json();
const stats = playerData.LifetimeStatistics;
// Note that the fame appears to be slow to update (i think a month behind!)

// Generate Tags
const playerTags = generatePlayerTags(playerData);

// Gathering Data
const FiberFame = stats.Gathering.Fiber.Total;
const FiberTier = GetGatheringProgrssion(FiberFame, "Fiber");
const FiberTierColor = TierColors[FiberTier as keyof typeof TierColors];

const HideFame = stats.Gathering.Hide.Total;
const HideTier = GetGatheringProgrssion(HideFame, "Hide");
const HideTierColor = TierColors[HideTier as keyof typeof TierColors];

const OreFame = stats.Gathering.Ore.Total;
const OreTier = GetGatheringProgrssion(OreFame, "Ore");
const OreTierColor = TierColors[OreTier as keyof typeof TierColors];

// The api property is Rock but utils uses Stone
const StoneFame = stats.Gathering.Rock.Total;
const StoneTier = GetGatheringProgrssion(StoneFame, "Stone");
const StoneTierColor = TierColors[StoneTier as keyof typeof TierColors];

const WoodFame = stats.Gathering.Wood.Total;
const WoodTier = GetGatheringProgrssion(WoodFame, "Wood");
const WoodTierColor = TierColors[WoodTier as keyof typeof TierColors];

const FishingFame = stats.FishingFame;
const FishingTier = GetGatheringProgrssion(FishingFame, "Fishing");
const FishingTierColor = TierColors[FishingTier as keyof typeof TierColors];
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Resume : {playerData.Name}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700;800&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body
		class="bg-slate-950 text-slate-100 min-h-screen font-['Outfit'] selection:bg-blue-500/30"
	>
		<!-- Background Elements -->
		<div
			class="fixed top-[-10%] left-[-10%] w-[40%] h-[40%] rounded-full bg-blue-600/20 blur-[120px] pointer-events-none"
		>
		</div>
		<div
			class="fixed bottom-[-10%] right-[-10%] w-[40%] h-[40%] rounded-full bg-purple-600/20 blur-[120px] pointer-events-none"
		>
		</div>

		<main class="max-w-6xl mx-auto p-4 md:p-8 relative z-10">
			<!-- Header / Profile Section -->
			<header
				class="flex flex-col md:flex-row items-center md:items-start justify-between gap-6 backdrop-blur-md bg-white/5 border border-white/10 p-8 rounded-2xl shadow-2xl mb-8 transition-transform hover:-translate-y-1 duration-300"
			>
				<div
					class="flex flex-col gap-4 items-center md:items-start w-full"
				>
					<div
						class="flex flex-col md:flex-row items-center gap-6 w-full"
					>
						<!-- Avatar Placeholder (using generic ring if available, or just a cool initial) -->
						<div
							class="relative w-32 h-32 rounded-full border-4 border-slate-700 bg-slate-800 flex items-center justify-center shadow-[0_0_20px_rgba(59,130,246,0.3)] shrink-0 overflow-hidden group"
						>
							<span
								class="text-5xl font-extrabold text-blue-400 group-hover:scale-110 transition-transform duration-300"
								>{playerData.Name.charAt(0)}</span
							>
						</div>

						<div class="flex-1 text-center md:text-left">
							<h1
								class="text-5xl font-extrabold bg-gradient-to-r from-blue-400 to-purple-400 bg-clip-text text-transparent mb-2"
							>
								{playerData.Name}
							</h1>
							<p class="text-slate-400 font-semibold mb-2">
								ID: <span
									class="text-slate-500 font-mono text-sm"
									>{playerData.Id}</span
								>
							</p>

							{
								playerData.GuildName && (
									<p class="text-lg text-slate-300 inline-block px-3 py-1 rounded-full bg-slate-800/50 border border-slate-700 mb-3">
										{playerData.AllianceTag ? (
											<span class="text-blue-300 font-bold">
												[{playerData.AllianceTag}]{" "}
											</span>
										) : (
											""
										)}
										<span class="font-semibold">
											{playerData.GuildName}
										</span>
										{playerData.AllianceName && (
											<span class="text-slate-400 font-medium ml-1">
												- {playerData.AllianceName}
											</span>
										)}
									</p>
								)
							}

							<!-- Dynamic Tags -->
							<div
								class="flex flex-wrap gap-2 justify-center md:justify-start mt-2"
							>
								{
									playerTags.map((tag) => (
										<span
											class={`px-3 py-1 text-sm rounded-full font-bold uppercase tracking-wider ${tag.color}`}
										>
											{tag.label}
										</span>
									))
								}
								{
									playerTags.length === 0 && (
										<span class="px-3 py-1 text-sm rounded-full font-bold uppercase tracking-wider bg-slate-700 text-slate-300 border border-slate-500">
											Adventurer
										</span>
									)
								}
							</div>
						</div>
					</div>

					<div
						class="flex flex-wrap gap-4 mt-4 w-full justify-center md:justify-start border-t border-white/10 pt-4"
					>
						<div class="flex items-center gap-2">
							<span class="text-green-400 font-bold text-xl"
								>{
									formatNumberToLetter(playerData.KillFame)
								}</span
							>
							<span
								class="text-slate-400 text-sm uppercase tracking-widest"
								>Kill Fame</span
							>
						</div>
						<div class="w-px bg-white/20 hidden md:block"></div>
						<div class="flex items-center gap-2">
							<span class="text-red-400 font-bold text-xl"
								>{
									formatNumberToLetter(playerData.DeathFame)
								}</span
							>
							<span
								class="text-slate-400 text-sm uppercase tracking-widest"
								>Death Fame</span
							>
						</div>
						<div class="w-px bg-white/20 hidden md:block"></div>
						<div class="flex items-center gap-2">
							<span class="text-purple-400 font-bold text-xl"
								>{
									(
										playerData.KillFame /
										(playerData.DeathFame || 1)
									).toFixed(2)
								}</span
							>
							<span
								class="text-slate-400 text-sm uppercase tracking-widest"
								>K/D Ratio</span
							>
						</div>
					</div>
				</div>
			</header>

			<div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
				<!-- Left Column: Skills (Gathering & Farming) -->
				<div class="lg:col-span-5 flex flex-col gap-8">
					<section
						class="backdrop-blur-md bg-white/5 border border-white/10 rounded-2xl p-6 shadow-xl hover:-translate-y-1 transition-transform duration-300"
					>
						<h2
							class="text-2xl font-bold border-b border-white/10 pb-3 mb-6 flex items-center gap-2"
						>
							<svg
								class="w-6 h-6 text-blue-400"
								fill="none"
								stroke="currentColor"
								viewBox="0 0 24 24"
								><path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
								></path></svg
							>
							Proficiencies
						</h2>

						<div class="grid grid-cols-2 gap-4">
							<div
								class="flex flex-col items-center p-3 rounded-xl shadow-lg border border-white/5 group"
								style={`background-color: ${FiberTierColor}20`}
							>
								<img
									class="w-16 h-16 object-contain group-hover:scale-110 transition-transform"
									src={`https://render.albiononline.com/v1/item/T${FiberTier}_2H_TOOL_SICKLE?quality=5`}
									alt="Fiber"
								/>
								<p class="font-bold mt-2">Fiber</p>
								<p class="text-sm font-mono opacity-80">
									{formatNumberToLetter(FiberFame)}
								</p>
								<span
									class="text-xs font-bold px-2 py-0.5 mt-1 rounded bg-black/40"
									>Tier {FiberTier}</span
								>
							</div>
							<div
								class="flex flex-col items-center p-3 rounded-xl shadow-lg border border-white/5 group"
								style={`background-color: ${HideTierColor}20`}
							>
								<img
									class="w-16 h-16 object-contain group-hover:scale-110 transition-transform"
									src={`https://render.albiononline.com/v1/item/T${HideTier}_2H_TOOL_KNIFE?quality=5`}
									alt="Hide"
								/>
								<p class="font-bold mt-2">Hide</p>
								<p class="text-sm font-mono opacity-80">
									{formatNumberToLetter(HideFame)}
								</p>
								<span
									class="text-xs font-bold px-2 py-0.5 mt-1 rounded bg-black/40"
									>Tier {HideTier}</span
								>
							</div>
							<div
								class="flex flex-col items-center p-3 rounded-xl shadow-lg border border-white/5 group"
								style={`background-color: ${OreTierColor}20`}
							>
								<img
									class="w-16 h-16 object-contain group-hover:scale-110 transition-transform"
									src={`https://render.albiononline.com/v1/item/T${OreTier}_2H_TOOL_PICK?quality=5`}
									alt="Ore"
								/>
								<p class="font-bold mt-2">Ore</p>
								<p class="text-sm font-mono opacity-80">
									{formatNumberToLetter(OreFame)}
								</p>
								<span
									class="text-xs font-bold px-2 py-0.5 mt-1 rounded bg-black/40"
									>Tier {OreTier}</span
								>
							</div>
							<div
								class="flex flex-col items-center p-3 rounded-xl shadow-lg border border-white/5 group"
								style={`background-color: ${StoneTierColor}20`}
							>
								<img
									class="w-16 h-16 object-contain group-hover:scale-110 transition-transform"
									src={`https://render.albiononline.com/v1/item/T${StoneTier}_2H_TOOL_HAMMER?quality=5`}
									alt="Stone"
								/>
								<p class="font-bold mt-2">Stone</p>
								<p class="text-sm font-mono opacity-80">
									{formatNumberToLetter(StoneFame)}
								</p>
								<span
									class="text-xs font-bold px-2 py-0.5 mt-1 rounded bg-black/40"
									>Tier {StoneTier}</span
								>
							</div>
							<div
								class="flex flex-col items-center p-3 rounded-xl shadow-lg border border-white/5 group"
								style={`background-color: ${WoodTierColor}20`}
							>
								<img
									class="w-16 h-16 object-contain group-hover:scale-110 transition-transform"
									src={`https://render.albiononline.com/v1/item/T${WoodTier}_2H_TOOL_AXE?quality=5`}
									alt="Wood"
								/>
								<p class="font-bold mt-2">Wood</p>
								<p class="text-sm font-mono opacity-80">
									{formatNumberToLetter(WoodFame)}
								</p>
								<span
									class="text-xs font-bold px-2 py-0.5 mt-1 rounded bg-black/40"
									>Tier {WoodTier}</span
								>
							</div>
							<div
								class="flex flex-col items-center p-3 rounded-xl shadow-lg border border-white/5 group"
								style={`background-color: ${FishingTierColor}20`}
							>
								<img
									class="w-16 h-16 object-contain group-hover:scale-110 transition-transform"
									src={`https://render.albiononline.com/v1/item/T${FishingTier}_2H_TOOL_FISHINGROD?quality=5`}
									alt="Fishing"
								/>
								<p class="font-bold mt-2">Fishing</p>
								<p class="text-sm font-mono opacity-80">
									{formatNumberToLetter(FishingFame)}
								</p>
								<span
									class="text-xs font-bold px-2 py-0.5 mt-1 rounded bg-black/40"
									>Tier {FishingTier}</span
								>
							</div>
						</div>
					</section>

					<section
						class="backdrop-blur-md bg-white/5 border border-white/10 rounded-2xl p-6 shadow-xl hover:-translate-y-1 transition-transform duration-300"
					>
						<h2
							class="text-2xl font-bold border-b border-white/10 pb-3 mb-6 flex items-center gap-2"
						>
							<svg
								class="w-6 h-6 text-lime-400"
								fill="none"
								stroke="currentColor"
								viewBox="0 0 24 24"
								><path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
								></path></svg
							>
							Farming Experience
						</h2>
						<div
							class="flex items-center justify-between p-4 bg-slate-800/50 rounded-xl border border-white/5"
						>
							<span class="font-semibold text-lg">Total Fame</span
							>
							<span
								class="text-2xl font-bold font-mono text-lime-400"
								>{formatNumberToLetter(stats.FarmingFame)}</span
							>
						</div>
					</section>
				</div>

				<!-- Right Column: Experience (PvE & Crafting) -->
				<div class="lg:col-span-7 flex flex-col gap-8">
					<section
						class="backdrop-blur-md bg-white/5 border border-white/10 rounded-2xl p-6 shadow-xl hover:-translate-y-1 transition-transform duration-300"
					>
						<h2
							class="text-2xl font-bold border-b border-white/10 pb-3 mb-6 flex items-center gap-2"
						>
							<svg
								class="w-6 h-6 text-purple-400"
								fill="none"
								stroke="currentColor"
								viewBox="0 0 24 24"
								><path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg
							>
							PvE Expertise
						</h2>

						<div class="grid grid-cols-2 gap-4">
							<div
								class="p-4 bg-slate-800/50 rounded-xl border border-white/5 hover:bg-slate-800 transition-colors"
							>
								<p
									class="text-slate-400 text-sm uppercase tracking-wider font-semibold"
								>
									Royals
								</p>
								<p class="text-2xl font-bold font-mono">
									{formatNumberToLetter(stats.PvE.Royal)}
								</p>
							</div>
							<div
								class="p-4 bg-slate-800/50 rounded-xl border border-white/5 hover:bg-slate-800 transition-colors"
							>
								<p
									class="text-slate-400 text-sm uppercase tracking-wider font-semibold"
								>
									Outlands
								</p>
								<p
									class="text-2xl font-bold font-mono text-purple-400"
								>
									{formatNumberToLetter(stats.PvE.Outlands)}
								</p>
							</div>
							<div
								class="p-4 bg-slate-800/50 rounded-xl border border-white/5 hover:bg-slate-800 transition-colors"
							>
								<p
									class="text-slate-400 text-sm uppercase tracking-wider font-semibold"
								>
									Avalon
								</p>
								<p
									class="text-2xl font-bold font-mono text-cyan-400"
								>
									{formatNumberToLetter(stats.PvE.Avalon)}
								</p>
							</div>
							<div
								class="p-4 bg-slate-800/50 rounded-xl border border-white/5 hover:bg-slate-800 transition-colors"
							>
								<p
									class="text-slate-400 text-sm uppercase tracking-wider font-semibold"
								>
									Hellgate
								</p>
								<p
									class="text-2xl font-bold font-mono text-orange-500"
								>
									{formatNumberToLetter(stats.PvE.Hellgate)}
								</p>
							</div>
							<div
								class="p-4 bg-slate-800/50 rounded-xl border border-white/5 hover:bg-slate-800 transition-colors"
							>
								<p
									class="text-slate-400 text-sm uppercase tracking-wider font-semibold"
								>
									Corrupted Dungeon
								</p>
								<p
									class="text-2xl font-bold font-mono text-rose-500"
								>
									{
										formatNumberToLetter(
											stats.PvE.CorruptedDungeon,
										)
									}
								</p>
							</div>
							<div
								class="p-4 bg-slate-800/50 rounded-xl border border-white/5 hover:bg-slate-800 transition-colors"
							>
								<p
									class="text-slate-400 text-sm uppercase tracking-wider font-semibold"
								>
									The Mists
								</p>
								<p
									class="text-2xl font-bold font-mono text-indigo-400"
								>
									{formatNumberToLetter(stats.PvE.Mists)}
								</p>
							</div>
						</div>
					</section>

					<section
						class="backdrop-blur-md bg-white/5 border border-white/10 rounded-2xl p-6 shadow-xl hover:-translate-y-1 transition-transform duration-300"
					>
						<h2
							class="text-2xl font-bold border-b border-white/10 pb-3 mb-6 flex items-center gap-2"
						>
							<svg
								class="w-6 h-6 text-amber-400"
								fill="none"
								stroke="currentColor"
								viewBox="0 0 24 24"
								><path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"
								></path><path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"
								></path></svg
							>
							Crafting Specialization
						</h2>

						<div class="grid grid-cols-2 md:grid-cols-4 gap-4">
							<div
								class="p-4 bg-slate-800/50 rounded-xl border border-white/5 text-center"
							>
								<p
									class="text-slate-400 text-xs uppercase tracking-wider font-semibold mb-1"
								>
									Total
								</p>
								<p
									class="text-xl font-bold font-mono text-amber-400"
								>
									{formatNumberToLetter(stats.Crafting.Total)}
								</p>
							</div>
							<div
								class="p-4 bg-slate-800/50 rounded-xl border border-white/5 text-center"
							>
								<p
									class="text-slate-400 text-xs uppercase tracking-wider font-semibold mb-1"
								>
									Royals
								</p>
								<p class="text-xl font-bold font-mono">
									{formatNumberToLetter(stats.Crafting.Royal)}
								</p>
							</div>
							<div
								class="p-4 bg-slate-800/50 rounded-xl border border-white/5 text-center"
							>
								<p
									class="text-slate-400 text-xs uppercase tracking-wider font-semibold mb-1"
								>
									Outlands
								</p>
								<p
									class="text-xl font-bold font-mono text-purple-400"
								>
									{
										formatNumberToLetter(
											stats.Crafting.Outlands,
										)
									}
								</p>
							</div>
							<div
								class="p-4 bg-slate-800/50 rounded-xl border border-white/5 text-center"
							>
								<p
									class="text-slate-400 text-xs uppercase tracking-wider font-semibold mb-1"
								>
									Avalon
								</p>
								<p
									class="text-xl font-bold font-mono text-cyan-400"
								>
									{
										formatNumberToLetter(
											stats.Crafting.Avalon,
										)
									}
								</p>
							</div>
						</div>

						{
							config.craftingSpecalties &&
								config.craftingSpecalties.length > 0 && (
									<div class="mt-6 border-t border-white/10 pt-4">
										<p class="text-slate-400 text-xs uppercase tracking-wider font-semibold mb-3">
											Specialties
										</p>
										<div class="flex flex-wrap gap-2">
											{config.craftingSpecalties.map(
												(specialty) => (
